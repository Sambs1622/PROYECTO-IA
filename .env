# ============================================================
# ASISTENTE DE VOZ TPM - CONFIGURACIÓN DE API KEYS
# ============================================================
# Copia este archivo como ".env" y completa tus credenciales
# ============================================================

# --- LiveKit Cloud (GRATIS en cloud.livekit.io) ---
# 1. Crea cuenta en https://cloud.livekit.io
# 2. Crea un nuevo proyecto
# 3. Copia la URL, API Key y API Secret

LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxx

# --- Deepgram (GRATIS - $200 créditos en deepgram.com) ---
# 1. Crea cuenta en https://deepgram.com
# 2. Ve a Dashboard → API Keys → Create Key
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Gemini (GRATIS en aistudio.google.com) ---
# 1. Ve a https://aistudio.google.com/app/apikey
# 2. Crea una API Key
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI TTS (para la voz de respuesta) ---
# Opción 1: OpenAI ($5 mínimo en platform.openai.com)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Configuración del servidor ---
SERVER_PORT=8080
ROOM_NAME=tpm-assistant
